# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Operator's real config (never commit — may contain real paths/secrets)
config.yaml

# Herder runtime state
.herder/

# Eval run artifacts (keep the dir, ignore generated reports)
evals/outputs/*
!evals/outputs/.gitkeep
