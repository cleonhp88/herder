<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.herder.worker</string>
  <key>ThrottleInterval</key>
  <integer>30</integer>
  <key>ProgramArguments</key>
  <array>
    <string>__HERDER_DIR__/launchd/herder-worker-launch.sh</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__HERDER_DIR__</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>__HERDER_HOME__/worker.log</string>
  <key>StandardErrorPath</key>
  <string>__HERDER_HOME__/worker.err.log</string>
</dict>
</plist>
